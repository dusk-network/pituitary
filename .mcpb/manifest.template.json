{
  "manifest_version": "0.2",
  "name": "pituitary",
  "version": "${VERSION}",
  "description": "Catch spec drift before it catches you. Detect overlap, stale docs, and code drift.",
  "author": {
    "name": "Dusk Network",
    "url": "https://github.com/dusk-network"
  },
  "server": {
    "type": "binary",
    "entry_point": "pituitary",
    "mcp_config": {
      "command": "${__dirname}/pituitary",
      "args": ["serve"],
      "env": {}
    }
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/dusk-network/pituitary",
    "type": "git"
  }
}
